{% extends 'base.html.j2' %}

{% block title %}首頁{% endblock %}

{% block content %}
<style>
    form {
        margin-top: 20px;
    }
    label {
        display: block;
        margin-bottom: 10px;
        font-weight: bold;
    }
    input[type="file"] {
        margin-bottom: 20px;
    }
    input[type="submit"] {
        background-color: #007bff;
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 5px;
        cursor: pointer;
        font-size: 16px;
    }
    input[type="submit"]:hover {
        background-color: #0056b3;
    }
</style>
<h1>上傳檔案</h1>
<p>請上傳電路 (.xml) 和規則 (.yaml) 檔案以開始檢查。</p>
<form action="/check" method="post" enctype="multipart/form-data">
    <label for="xml_file">電路 .xml 檔案:</label>
    <input type="file" name="xml_file" id="xml_file" accept=".xml" required>
    <br>
    <label for="yaml_file">規則 .yaml 檔案:</label>
    <input type="file" name="yaml_file" id="yaml_file" accept=".yaml,.yml" required>
    <br>
    <input type="submit" value="執行檢查">
</form>
{% endblock %}
