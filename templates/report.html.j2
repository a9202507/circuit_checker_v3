{% extends 'base.html.j2' %}

{% block title %}檢查報告{% endblock %}

{% block content %}
  <h1>檢查報告</h1>
  <p><b>總結:</b> 共 {{ summary.total }} 項發現 (錯誤: {{ summary.errors }}, 警告: {{ summary.warnings }}, 資訊: {{ summary.info }})</p>
  
  {% if findings %}
  <table>
    <thead>
      <tr>
        <th>#</th>
        <th>嚴重性</th>
        <th>規則 ID</th>
        <th>訊息</th>
        <th>元素</th>
        <th>位置</th>
      </tr>
    </thead>
    <tbody>
    {% for f in findings %}
      <tr>
        <td>{{ loop.index }}</td>
        <td class="{{ 'error' if f.severity=='ERROR' else 'warn' if f.severity=='WARN' else '' }}">{{ f.severity }}</td>
        <td>{{ f.rule_id }}</td>
        <td>{{ f.message }}</td>
        <td>{{ f.element_ref.tag }}</td>
        <td>path: {{ f.element_ref.path }} {% if f.element_ref.line %} (line {{ f.element_ref.line }}){% endif %}</td>
      </tr>
    {% endfor %}
    </tbody>
  </table>
  {% else %}
  <p>太好了！沒有發現任何問題。</p>
  {% endif %}
{% endblock %}
